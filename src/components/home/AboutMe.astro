---
import {aboutMeData} from "../../const/homeData";
---

<section
  id="aboutme"
  class="container mx-auto my-36 px-6 lg:px-12 max-w-screen-xl"
>
  <div class="bg-[var(--color-light)] rounded-lg overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
      <!-- Image Section - Optimized with responsive sizes -->
      <div class="relative p-6 flex items-center justify-center">
        <picture>
          <source
            srcset="/src/images/homePage/portrait1.webp 400w"
            sizes="(max-width: 640px) 400px,
                   (max-width: 1024px) 600px,
                   800px"
            type="image/webp"
          />
          <img
            src="/src/images/homePage/portrait1.webp"
            alt={`Portrait of ${aboutMeData.title}`}
            width="600"
            height="800"
            loading="lazy"
            decoding="async"
            class="shadow-md object-cover max-h-[550px] w-auto"
          />
        </picture>
      </div>

      <!-- Text Section -->
      <div class="p-8 lg:p-12 flex flex-col justify-center">
        <h2 class="text-3xl lg:text-4xl font-bold mb-1 text-[var(--color-dark)]">
          {aboutMeData.title}
        </h2>
        <h3 class="text-md lg:text-xl font-bold mb-8 text-[var(--color-dark)]">
          MASÉR TERAPEUT
        </h3>
        <div class="space-y-6 text-[var(--color-dark)]">
          <p class="leading-relaxed about-text">
            {aboutMeData.descriptionOne}
          </p>
          <p class="leading-relaxed about-text">
            {aboutMeData.descriptionTwo}
          </p>
          <p class="font-bold leading-relaxed about-text">
            {aboutMeData.descriptionThree}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
    .about-text {
        text-align: left;
        overflow-wrap: break-word;
        word-wrap: break-word;
    }
</style>