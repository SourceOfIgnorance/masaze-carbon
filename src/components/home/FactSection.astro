---
import {Image} from 'astro:assets';
import bgImage from '../../assets/homePage/factsBg.png';

const benefitsData = {
  title: "Masáž so sebou nesie mnoho benefitov",
  benefitsTitle: [
    "Podpora cirkulácie krvi a lymfy",
    "Zlepšenie kvality spánku",
    "Účinná pomoc pri zraneniach",
    "Úľava od psychického napätia"
  ],
  benefitText: [
    "Masáže priaznivo ovplyvňujú prekrvenie tela a lymfatický tok, čím napomáhajú lepšiemu okysličeniu a výžive buniek. Vďaka tomu sa zrýchľuje metabolizmus, uvoľňujú sa stuhnuté svaly a telo sa efektívnejšie zbavuje toxínov.",
    "Masáž pomáha telu prejsť do hlbšieho stavu relaxácie, čo môže pozitívne ovplyvniť spánkový režim. Mnoho ľudí po masáži udáva lepší a kvalitnejší spánok, bez prerušovania.",
    "Masáže sú často súčasťou rehabilitácie a liečby rôznych fyzických ťažkostí. Uvoľnenie svalových blokád a zlepšenie flexibility kĺbov môže významne prispieť k úľave od chronickej bolesti a urýchliť hojenie po úrazoch.",
    "Masáže sú prirodzený spôsob, ako si dopriať duševný oddych. Počas masáže dochádza k uvoľňovaniu hormónov dobrej nálady, ako sú endorfíny a serotonín, ktoré znižujú hladinu stresových hormónov a navodzujú pocit pokoja a pohody.",
  ],
}
---

<section id="benefits" class="relative pt-8 mb-8 md:py-12" aria-labelledby="benefits-title">
  <!-- Optimized background image with Astro Image -->
  <div class="absolute inset-0 -z-10">
    <Image
      src={bgImage}
      alt="Masážne benefity - pozadie"
      class="w-full h-full object-cover"
      fill
      sizes="100vw"
      placeholder="blur"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 text-center">
    <h2 id="benefits-title" class="mb-12 text-2xl md:text-3xl font-semibold text-[var(--color-light)]">
      {benefitsData.title}
    </h2>

    <!-- Expandable grid -->
    <div
      id="benefits-grid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10
        relative max-h-96 overflow-hidden transition-all duration-300 sm:max-h-none"
    >
      {benefitsData.benefitsTitle.map((title, index) => (
        <article class="p-6">
          <h3 class="mb-4 text-lg font-medium text-[var(--color-light)]">{title}</h3>
          <p class="text-[var(--color-light)] leading-relaxed text-sm md:text-base">
            {benefitsData.benefitText[index]}
          </p>
        </article>
      ))}
    </div>

    {/* Shadow and Expand Button (mobile only, and only when collapsed) */}
    <div
      id="benefits-shadow"
      class="absolute left-0 right-0 bottom-0 h-16 pointer-events-none bg-gradient-to-t from-[var(--color-light)]/80 to-transparent flex justify-center items-end sm:hidden"
      style="transition: opacity 0.3s"
    >
      <button
        id="benefits-expand"
        class="mx-auto mb-2 w-8 h-8 rounded-full flex items-center justify-center bg-[var(--color-light)] shadow cursor-pointer border border-[var(--color-dark)]"
        aria-label="Zobraziť viac"
        style="pointer-events:auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-dark)]" fill="none"
             viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const grid = document.getElementById('benefits-grid');
      const shadow = document.getElementById('benefits-shadow');
      const expandBtn = document.getElementById('benefits-expand');
      if (!grid || !shadow || !expandBtn) return;

      expandBtn.addEventListener('click', () => {
        grid.classList.remove('max-h-96', 'overflow-hidden');
        shadow.style.opacity = '0';
        setTimeout(() => {
          shadow.style.display = 'none';
        }, 300); // match transition duration
      });
    });
  </script>
</section>
