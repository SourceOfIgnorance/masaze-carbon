---
import {Image} from "astro:assets";
// import heroBg1 from "../../assets/homePage/masirovanie-zeny-titulka.png";
import heroBg2 from "../../assets/homePage/masazny-priestor-titulka-1.jpeg";
import heroBg3 from "../../assets/homePage/masazny-priestor-titulka-2.jpeg";

const {
  title = "Masáže Carbon",
  subtitle = "Oddýchnite si v rukách skúseného terapeuta a profesionálneho maséra.",
} = Astro.props;
---

<style is:inline>
    .hero-section {
        min-height: 100vh;
        position: relative;
    }
    .text-shadow-sm {
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }
</style>

<section class="relative overflow-hidden w-full h-screen flex flex-col justify-center items-center">
  <!-- Responsive, blurred background image -->
  <div class="absolute inset-0 -z-10">
    <Image id="hero-image"
           src={heroBg3}
           alt="Masážne štúdio Carbon - pozadie"
           fill
           class="object-cover object-left w-full h-full"
           placeholder="blur"
           sizes="(max-width: 640px) 100vw, 1920px"
           priority
    />
    <!-- Blurring and dark overlay for readability -->
    <div class="absolute inset-0 bg-black/30 backdrop-blur-sm"></div>
  </div>

  <!-- Content -->
  <div class="relative text-center text-[var(--color-light)] z-10">
    <h1 class="text-4xl md:text-6xl font-bold mb-6 text-shadow-sm">{title}</h1>
    <p class="text-xl md:text-xl text-shadow-sm mx-6">{subtitle}</p>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-24 left-0 right-0 flex justify-center items-center">
    <button
      class="w-12 h-12 rounded-full bg-[var(--color-light)] flex justify-center items-center cursor-pointer animate-bounce shadow-lg"
      aria-label="Prejst ďalej"
      onclick="window.scrollTo({top: window.innerHeight, behavior: 'smooth'})"
      type="button"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 text-[var(--color-dark)]"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="3"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
  </div>
</section>
