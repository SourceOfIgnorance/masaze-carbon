---
import {heroData} from '../../const/homeData';
---

<section
  class="relative overflow-hidden w-full h-screen flex flex-col justify-center items-center"
>
  <picture class="absolute inset-0">
    <source
      srcset="/src/images/homePage/heroBg-800.webp 800w,
              /src/images/homePage/heroBg-1200.webp 1200w,
              /src/images/homePage/heroBg-1920.webp 1920w"
      sizes="100vw"
      type="image/webp"
    />
    <!-- Fallback image -->
    <img
      src="/src/images/homePage/heroBg-1200.webp"
      alt="Hero background"
      class="w-full h-full object-cover"
      width="1920"
      height="1080"
      fetchpriority="high"
    />
  </picture>
  <div class="absolute inset-0 bg-black/20 backdrop-blur-sm"></div>
  <!-- Content -->
  <div class="relative text-center text-[var(--color-light)] z-10">
    <h1 class="text-2xl md:text-7xl font-bold mb-6 text-shadow-sm">
      {heroData.title}
    </h1>
    <p class="text-xl md:text-xl text-shadow-sm">
      {heroData.subtitle}
    </p>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-25 flex justify-center items-center">
    <button
      class="w-12 h-12 rounded-full bg-[var(--color-light)] flex justify-center items-center cursor-pointer animate-bounce"
      aria-label="Scroll down"
      onclick="document.documentElement.scrollTo({top: window.innerHeight, behavior: 'smooth'})"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 text-[var(--color-dark)]"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="3"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19 9l-7 7-7-7"
        />
      </svg>
    </button>
  </div>
</section>