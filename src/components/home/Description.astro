---
import {Image} from 'astro:assets';
import descImage from '../../assets/homePage/descBg.png';

const descriptionData = {
  title: "Komplexná starostlivosť o telo",
  description: `
Spolu s Robertom Bezakom poskytujeme v Pohybovo komplexnú a individuálne prispôsobenú starostlivosť. Prepájame terapeutickú masáž s odbornými zásahmi do pohybového aparátu pre efektívnejšiu a trvalejšiu úľavu.

Naše služby spájajú výhody masáže a fyzioterapie tak, aby ste sa po každej návšteve cítili lepšie – po fyzickej aj psychickej stránke. Masáže, ktoré ponúkam, sú zamerané na uvoľnenie svalového napätia, podporu cirkulácie a celkovú regeneráciu. Pravidelná starostlivosť o telo je nielen prevenciou, ale aj cestou k dlhodobej pohode.

Ak hľadáte spôsob, ako sa zbaviť stresu, bolesti či napätia, ste na správnom mieste.
  `.trim(),
};

const expanded = false; // initial state for hydration-less SSR, JS will control actual state
---

<section id="description" class="container mx-auto my-36 px-6 lg:px-12 max-w-screen-xl">
  <div class="bg-[var(--color-light)] rounded-lg shadow-xl overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
      <div class="w-full h-80 lg:h-auto relative">
        <Image
          src={descImage}
          alt="Masážne štúdio Topoľčany - pohybová terapia a individuálna starostlivosť"
          class="object-cover w-full h-full rounded-xl"
          fill
          sizes="(max-width: 1024px) 100vw, 50vw"
          placeholder="blur"
          loading="lazy"
        />
      </div>

      <!-- TEXT SECTION -->
      <div
        id="desc-text-container"
        class="relative p-8 lg:p-12 flex flex-col justify-start text-[var(--color-dark)] transition-all duration-300 max-h-96 overflow-hidden sm:max-h-none">
        <!-- Only limit height on mobile -->
        <h2 class="text-3xl lg:text-4xl font-bold mb-8">{descriptionData.title}</h2>
        <div>
          <p class="text-lg leading-relaxed whitespace-pre-line">
            {descriptionData.description}
          </p>
        </div>

        <!-- Shadow and Arrow (only visible when not expanded, and on mobile) -->
        <div
          id="desc-shadow"
          class="absolute left-0 right-0 bottom-0 h-20 pointer-events-none bg-gradient-to-t from-[var(--color-light)] to-transparent flex justify-center items-end sm:hidden"
          style="(transition: opacity 0.3s)"
        >
          <button
            id="desc-expand"
            class="mx-auto mb-2 w-8 h-8 rounded-full flex items-center justify-center bg-[var(--color-light)] shadow cursor-pointer border border-[var(--color-dark)]"
            aria-label="Zobraziť viac"
            style="pointer-events:auto"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-dark)]" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // This script should be placed in the page or layout where this section appears.
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById('desc-text-container');
    const shadow = document.getElementById('desc-shadow');
    const expandBtn = document.getElementById('desc-expand');

    if (!container || !shadow || !expandBtn) return;

    expandBtn.addEventListener('click', () => {
      container.classList.remove('max-h-96', 'overflow-hidden');
      shadow.style.opacity = '0';
      setTimeout(() => {
        shadow.style.display = 'none';
      }, 300); // match transition duration
    });
  });
</script>
