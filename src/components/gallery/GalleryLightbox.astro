---
const {images} = Astro.props;
---

<div class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-80 hidden" id="lightbox">
  <button class="absolute top-4 right-4 text-white text-3xl" id="closeBtn">&times;</button>
  <button class="absolute left-4 text-white text-3xl" id="prevBtn">&lt;</button>
  <img src="" alt="" class="max-h-[80vh] max-w-full rounded shadow-lg" id="lightboxImg">
  <button class="absolute right-4 text-white text-3xl" id="nextBtn">&gt;</button>
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white" id="counter"></div>
</div>

<style>
    #lightbox.hidden {
        display: none;
    }

    #lightbox {
        display: flex;
    }
</style>

<span id="imagesData" class="hidden">{JSON.stringify(images)}</span>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg');
    const closeBtn = document.getElementById('closeBtn');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const counter = document.getElementById('counter');

    const images = JSON.parse(document.getElementById('imagesData').textContent);

    let idx = 0;
    let open = false;

    const updateLightbox = () => {
      lightboxImg.src = images[idx].src;
      lightboxImg.alt = images[idx].alt;
      counter.textContent = `${idx + 1} / ${images.length}`;
    };

    closeBtn.addEventListener('click', () => {
      lightbox.classList.add('hidden');
      open = false;
    });

    prevBtn.addEventListener('click', () => {
      idx = (idx - 1 + images.length) % images.length;
      updateLightbox();
    });

    nextBtn.addEventListener('click', () => {
      idx = (idx + 1) % images.length;
      updateLightbox();
    });

    window.addEventListener('open-lightbox', (e) => {
      idx = e.detail.index;
      updateLightbox();
      lightbox.classList.remove('hidden');
      open = true;
    });
  });
</script>

