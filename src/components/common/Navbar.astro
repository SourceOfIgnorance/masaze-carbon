---
import Logo from "../icons/Logo.astro";
import SaleBadge from "./SaleBadge/SaleBadge.astro"
const navData = [
  {href: '/', label: 'Domov'},
  {href: '/cennik', label: 'Cenník'},
  {href: '/hodnotenia', label: 'Hodnotenia'},
  {href: '/galeria', label: 'Galéria'},
  {href: '/kontakt', label: 'Kontakt'},
];
---

<nav
  id="navbar"
  class="fixed w-full h-20 top-0 left-0 z-50 bg-transparent transition-colors duration-300"
  role="navigation"
  aria-label="Primary Navigation"
>
  <div class="container mx-auto flex items-center justify-start px-4 h-full">

    <!-- Logo -->
    <a href="/" aria-label="Homepage" class="flex items-center h-full">
      <Logo/>
    </a>
    <div class="flex items-center justify-end ml-auto">
      <!-- Desktop Navigation Links -->
      <ul class="hidden md:flex space-x-6 text-[var(--color-light)] pr-4">
        {navData.map((item) => (
          <li key={item.href}>
            <a
              href={item.href}
              class="nav-link inline-block optimize-transition"
              data-link={item.label}
            >{item.label}</a
            >
          </li>
        ))}
      </ul>

      <!-- Desktop Buttons -->
      <div class="hidden md:flex items-center space-x-4">
        <button
          id="order-button"
          class="rounded-full bg-[var(--color-light)] text-[var(--color-dark)] px-5 py-2 font-semibold shadow transition-colors duration-300"
          type="button"
          aria-label="Prejsť na sekciu Kontakt"
        >
          Objednať
        </button>
        <!--Change color button-->
        <!--<button-->
        <!--  id="color-toggle"-->
        <!--  class="p-2 bg-[var(&#45;&#45;color-light)] text-[var(&#45;&#45;color-dark)] rounded shadow"-->
        <!--  aria-label="Switch color theme"-->
        <!--  type="button"-->
        <!--&gt;-->
        <!--  Zmeniť farbu-->
        <!--</button>-->
        <SaleBadge/>
      </div>

      <!-- Mobile Hamburger Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden p-2 rounded focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[var(--color-light)]"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Toggle menu"
        type="button"
      >
        <svg
          id="mobile-svg"
          class="w-6 h-6 transition-colors duration-300"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="opacity-0 pointer-events-none fixed top-20 inset-x-0 bg-[var(--color-dark)] transition-opacity duration-300 ease-in-out md:hidden"
    aria-hidden="true"
  >
    <ul id="mobile-menu-list" class="flex flex-col space-y-4 p-6">
      {navData.map((item) => (
        <li key={item.href}>
          <a href={item.href} class="block nav-link" data-link={item.label}>
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <button
          id="mobile-order-button"
          class="w-full rounded-full bg-[var(--color-light)] text-[var(--color-dark)] px-5 py-2 font-semibold shadow transition-colors duration-300"
          type="button"
          aria-label="Prejsť na sekciu objednať"
        >
          Objednať
        </button>
      </li>
      <!--Change color button-->
      <!--<li>-->
      <!--  <button-->
      <!--    id="mobile-color-toggle"-->
      <!--    class="w-full p-2 bg-[var(&#45;&#45;color-light)] text-[var(&#45;&#45;color-dark)] rounded shadow"-->
      <!--    aria-label="Switch color theme"-->
      <!--    type="button"-->
      <!--  >-->
      <!--    Zmeniť farbu-->
      <!--  </button>-->
      <!--</li>-->
    </ul>
  </div>
</nav>

<script type="module">
  const navbar = document.getElementById("navbar");
  const logo = document.getElementById("logo");
  const navLinks = document.querySelectorAll(".nav-link");
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileSvg = document.getElementById("mobile-svg");
  const orderButton = document.getElementById("order-button");
  const saleBadge = document.getElementById("sale-badge");
  const currentPath = window.location.pathname;

  // Helper to add/remove classes based on condition
  function toggleClass(el, className, condition) {
    if (condition) el.classList.add(className);
    else el.classList.remove(className);
  }

  // Update navbar colors and styles based on scroll, page, and menu state
  function updateNavbar() {
    const scrolled = window.scrollY > 0;
    const isHomePage = currentPath === "/";
    const menuOpen = mobileMenuButton.getAttribute("aria-expanded") === "true";

    // Determine if navbar background should be dark
    const darkBg = scrolled || menuOpen;

    // Navbar background
    toggleClass(navbar, "bg-[var(--color-dark)]", darkBg);
    toggleClass(navbar, "bg-transparent", !darkBg);

    // Logo color
    if (darkBg) {
      logo.classList.add("logo-light");
      logo.classList.remove("logo-dark");

      orderButton.classList.add("bg-[var(--color-light)]", !isHomePage);
      orderButton.classList.remove("bg-[var(--color-dark)]", !isHomePage);
      orderButton.classList.add("text-[var(--color-dark)]", !isHomePage);
      orderButton.classList.remove("text-[var(--color-light)]", !isHomePage);

      saleBadge.classList.toggle("badge-invert", true);
    } else {
      logo.classList.toggle("logo-light", isHomePage);
      logo.classList.toggle("logo-dark", !isHomePage);

      orderButton.classList.toggle("bg-[var(--color-light)]", isHomePage);
      orderButton.classList.toggle("text-[var(--color-dark)]", isHomePage);
      orderButton.classList.toggle("bg-[var(--color-dark)]", !isHomePage);
      orderButton.classList.toggle("text-[var(--color-light)]", !isHomePage);

      saleBadge.classList.toggle("badge-invert", isHomePage);
    }

    // Nav links color
    navLinks.forEach(link => {
      if (darkBg) {
        link.classList.add("text-[var(--color-light)]");
        link.classList.remove("text-[var(--color-dark)]");
      } else {
        link.classList.toggle("text-[var(--color-light)]", isHomePage);
        link.classList.toggle("text-[var(--color-dark)]", !isHomePage);
      }
    });

    // Hamburger icon color
    if (darkBg) {
      mobileSvg.classList.add("text-[var(--color-light)]");
      mobileSvg.classList.remove("text-[var(--color-dark)]");
    } else {
      mobileSvg.classList.toggle("text-[var(--color-light)]", isHomePage);
      mobileSvg.classList.toggle("text-[var(--color-dark)]", !isHomePage);
    }

    // Active link highlighting
    navLinks.forEach(link => {
      toggleClass(link, "active", link.getAttribute("href") === currentPath);
    });
  }

  // Mobile menu toggle handler
  mobileMenuButton.addEventListener("click", () => {
    const isExpanded = mobileMenuButton.getAttribute("aria-expanded") === "true";
    mobileMenuButton.setAttribute("aria-expanded", String(!isExpanded));

    if (!isExpanded) {
      mobileMenu.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu.classList.add("opacity-100", "pointer-events-auto");
    } else {
      mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
      mobileMenu.classList.add("opacity-0", "pointer-events-none");
    }

    updateNavbar();
  });

  // Smooth scroll on 'Objednať' buttons
  [
    document.getElementById("order-button"),
    document.getElementById("mobile-order-button"),
  ].filter(Boolean).forEach(btn => {
    btn.addEventListener("click", () => {
      const contactSection = document.getElementById("contact-section");
      if (contactSection) {
        contactSection.scrollIntoView({behavior: "smooth"});
        // Close mobile menu if open
        if (mobileMenuButton.getAttribute("aria-expanded") === "true") {
          mobileMenuButton.setAttribute("aria-expanded", "false");
          mobileMenu.classList.add("opacity-0", "pointer-events-none");
          mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
          updateNavbar();
        }
      }
    });
  });

  // Initialize and update on scroll
  updateNavbar();
  window.addEventListener("scroll", updateNavbar);
</script>
