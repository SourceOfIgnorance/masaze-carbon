---
import LoaderLogo from "../icons/LoaderLogo.astro";
---

<div id="loading-screen"
     class="fixed inset-0 z-[9999] flex flex-col items-center justify-center bg-[var(--color-light)]">
  <div id="logo-container" class="w-48 h-48 flex items-center justify-center">
  <LoaderLogo/>
  </div>
</div>
<style>
    @keyframes gentle-pulse {
        0%, 100% {
            transform: scale(1);
            opacity: 1;
        }
        50% {
            transform: scale(0.95);
            opacity: 0.8;
        }
    }

    #logo-container {
        animation: gentle-pulse 2s ease-in-out infinite;
    }
</style>

<script>
  // Logic to hide the loading screen once the page is fully loaded
  window.addEventListener('load', () => {
    // Give a slight delay (300ms) so the transition feels smoother
    setTimeout(() => {
      const loadingScreen = document.getElementById('loading-screen');
      if (loadingScreen) {
        loadingScreen.style.opacity = '0';
        loadingScreen.style.transition = 'opacity 0.8s ease-out';

        // Remove from DOM after transition
        setTimeout(() => {
          loadingScreen.style.display = 'none';
        }, 700);
      }
    }, 900);
  });
</script>
