<div
  id="mobile-sale-popup"
  class="fixed inset-0 z-50 flex items-center justify-center sm:hidden bg-black/40 opacity-0 transition-opacity duration-500"
  style="display: none;"
  role="dialog"
  aria-modal="true"
>
  <div class="bg-white rounded-lg shadow-lg p-4 max-w-xs w-full relative">
    <button
      id="close-popup"
      class="absolute top-2 right-5 text-gray-400 hover:text-gray-700 text-4xl font-bold"
      aria-label="Zavrieť"
      type="button"
    >&times;
    </button>
    <div class="text-sm">
      <p class="font-semibold mb-2 text-lg">Aktuálne zľavy na masáže!</p>
      <p class="mt-2 text-lg">🌿 1+1 zdarma<br/>
        Objednajte sa na masáž a získajte ďalšiu masáž zdarma pre blízku osobu.
      </p>
      <!--<p class="mt-2 text-lg">🌷 Deň matiek – zľava 30 %<br/>-->
      <!--  Doprajte svojej mame zaslúžený oddych. Zarezervujte jej masáž so zľavou 30 %.-->
      <!--</p>-->
      <div class="flex justify-end">
        <a href="/cennik#gift" class="px-3 py-2 rounded-sm text-md bg-[var(--color-dark)] text-[var(--color-light)] font-medium">
          Viac info
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  if (typeof window !== "undefined") {
    const isMobile = window.innerWidth < 640;
    const popup = document.getElementById('mobile-sale-popup');
    const closeBtn = document.getElementById('close-popup');

    function closePopup() {
      popup.classList.remove('opacity-100');
      setTimeout(() => {
        popup.style.display = 'none';
        sessionStorage.setItem('salePopupShown', 'true');
      }, 500);
    }

    if (isMobile && !sessionStorage.getItem('salePopupShown')) {
      setTimeout(() => {
        popup.style.display = 'flex';
        // Force a reflow to trigger the transition
        void popup.offsetWidth;
        popup.classList.add('opacity-100');
      }, 4000);
    }

    closeBtn?.addEventListener('click', closePopup);

    // Close popup when clicking outside the modal content
    popup.addEventListener('click', (event) => {
      if (event.target === popup) {
        closePopup();
      }
    });
  }
</script>
