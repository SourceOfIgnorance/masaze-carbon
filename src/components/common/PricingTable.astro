---
const {categoryTitle, services} = Astro.props;
import ServiceRow from './ServiceRow.astro';
---

<section class="mb-16 scroll-mt-24">
  <h2 class="text-2xl md:text-3xl font-bold mb-6 text-[var(--color-dark)]">{categoryTitle}</h2>
  <div class="bg-white rounded-lg shadow-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full min-w-[350px]">
        <tbody class="divide-y divide-gray-200">
        {services.map((service) => (
          <ServiceRow {...service}/>
        ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
