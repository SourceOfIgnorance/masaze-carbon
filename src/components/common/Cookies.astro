---
---
<!-- Cookie Consent Banner -->
<div id="cookie-banner"
     class="fixed bottom-0 left-0 w-full bg-[var(--color-dark)] text-[var(--color-light)] p-4 flex flex-col md:flex-row items-center justify-between z-50 shadow-lg transition-all"
     style="display: none;">
  <span>
    Používame iba nevyhnutné cookies a Google Maps, ktoré môžu ukladať cookies po vašom súhlase.
    <a href="/privacy-policy" class="underline ml-2">Zásady ochrany osobných údajov</a>
  </span>
  <div class="mt-2 md:mt-0 flex gap-2">
    <button id="accept-all"
            class="bg-blue-600 px-4 py-2 rounded hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-400">
      Prijať všetko
    </button>
    <button id="decline-analytics"
            class="bg-gray-600 px-4 py-2 rounded hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-500">
      Odmietnuť analytické
    </button>
  </div>
</div>

<!-- Manage Cookies Button (persistent) -->
<button id="manage-cookies-btn"
        class="hidden fixed bottom-4 left-4 bg-[var(--color-dark)] text-[var(--color-light)] px-4 py-2 rounded shadow-lg hover:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 z-50"
        aria-haspopup="dialog" aria-controls="cookie-preferences-modal" aria-expanded="false"
>
  Spravovať cookies
</button>

<!-- Cookie Preferences Modal -->
<div id="cookie-preferences-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title"
     class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50">
  <div class="bg-[var(--color-light)] rounded-lg max-w-md w-full p-6 relative shadow-lg">
    <h2 id="modal-title" class="text-xl font-semibold mb-4">Centrum preferencií cookies</h2>
    <form id="cookie-preferences-form" class="space-y-4">
      <div>
        <label class="inline-flex items-center">
          <input type="checkbox" name="necessary" checked disabled class="mr-2 cursor-not-allowed"/>
          Nevyhnutné cookies (vždy povolené)
        </label>
        <p class="text-sm text-gray-600 ml-6">Tieto cookies sú potrebné pre fungovanie webu.</p>
      </div>
      <div>
        <label class="inline-flex items-center">
          <input type="checkbox" name="googleMaps" class="mr-2"/>
          Google Maps cookies
        </label>
        <p class="text-sm text-gray-600 ml-6">Google Maps môže ukladať cookies po vašom súhlase.</p>
      </div>
      <div class="flex justify-end space-x-2 mt-6">
        <button type="button" id="preferences-cancel"
                class="px-4 py-2 rounded border border-gray-300 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-400">
          Zrušiť
        </button>
        <button type="submit"
                class="bg-blue-600 text-[var(--color-light)] px-4 py-2 rounded hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
          Uložiť nastavenia
        </button>
      </div>
    </form>
    <button id="preferences-close" aria-label="Zavrieť centrum preferencií"
            class="absolute top-3 right-3 text-gray-500 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-400 rounded">
      &times;
    </button>
  </div>
</div>
