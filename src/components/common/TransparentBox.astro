---
const {heading, description} = Astro.props;
---

<div
  class="w-full bg-[var(--color-dark-85)] py-12 px-6"
>
  <!-- Heading -->
  <div class="container mx-auto">
    <h2 class="text-[var(--color-light)] text-2xl md:text-3xl font-bold mb-4 text-center">{heading}</h2>

    <!-- Description -->
    <p class="text-[var(--color-light)] md:text-lg leading-relaxed text-center max-w-4xl mx-auto">{description}</p>
  </div>
</div>