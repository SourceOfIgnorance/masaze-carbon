---
import {address, socialLinks, mapIframeSrc, directions} from '../../const/contactData';
---

<section id="contact-section" class="py-16">
  <div class="container mx-auto px-6 lg:px-12 max-w-screen-xl">
    <!-- Content Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <!-- Left Column: Contact Information -->
      <div
        class="p-8 rounded-xl transform hover:shadow-lg transition-all duration-300 text-[var(--color-dark)]">
        <div class="space-y-6">
          <!-- Appointment Info -->
          <div>
            <h3 class="text-xl font-semibold mb-3 flex items-center">
              Objednávky
            </h3>
          </div>

          <!-- Contact Details -->
          <div>
            <div class="flex items-center mb-3">
              <p>Telefón:</p>
              <a href="tel:+421919236109" class="ml-2 transition-colors">
                +421 919 236 109
              </a>
            </div>

            <div class="flex items-center mb-3">
              <p>Email:</p>
              <a href="mailto:masaze.carbon@gmail.com" class="ml-2 transition-colors">
                masaze.carbon@gmail.com
              </a>
            </div>
          </div>

          <!-- Address -->
          <div>
            <h3 class="text-xl font-semibold mb-3 flex items-center">
              Kde ma nájdete
            </h3>
            <p class="mb-2">{address}</p>
            <p class="text-sm ">{directions}</p>
          </div>

          <!-- Social Media -->
          <div>
            <h3 class="text-xl font-semibold mb-3 flex items-center">
              Sledujte ma:
            </h3>
            <div class="flex space-x-4 ml-8">
              {socialLinks.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-2"
                >
                  <img
                    src={link.icon}
                    alt={link.alt}
                    class="h-6 w-6"
                  />
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Map -->
      <div class="h-full">
        <div class="rounded-xl overflow-hidden shadow-md h-full">
          <iframe
            src={mapIframeSrc}
            width="100%"
            height="450"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="w-full h-full min-h-[450px]"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
    #contact-section a {
        text-decoration: none;
    }

    #contact-section .social-icon:hover {
        filter: brightness(1.2);
    }
</style>