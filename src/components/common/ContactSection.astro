---
import {Image} from 'astro:assets';
import facebookIcon from '../../assets/icons/facebook-icon.png';
import instagramIcon from '../../assets/icons/instagram-icon.png';

export const businessName = "Masáže Carbon";
export const streetAddress = "Tovarnícka 412/9";
export const addressLocality = "Topoľčany";
export const postalCode = "955 01";
export const addressCountry = "SK";
export const phone = "+421919236109";
export const email = "masaze.carbon@gmail.com";
export const facebookUrl = "https://www.facebook.com/share/1C9hradLsV/";
export const instagramUrl = "https://www.instagram.com/masaze_carbon?igsh=YnpqZmo1MnNoNDZo";
export const openFrom = "08:00"
export const openUntil = "20:00"

export const address = `${businessName}, ${streetAddress}, ${postalCode} ${addressLocality}`;
export const directions = "Nachádzame sa na 1. poschodí v budove Carbon.";
export const mapIframeSrc =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d165.03647136594418!2d18.165796606608236!3d48.5603713259538!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x476b4b0063373029%3A0x7124fd43d1696af1!2zTWFzw6HFvmUgQ2FyYm9u!5e0!3m2!1sen!2ssk!4v1745959330335!5m2!1sen!2ssk";

// Create LocalBusiness schema
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "DaySpa",
  "name": businessName,
  "url": Astro.url.origin,
  "telephone": phone,
  "email": email,
  "description": "Profesionálne masážne služby v Topoľčanoch. Klasické, športové a hĺbkové masáže.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": streetAddress,
    "addressLocality": addressLocality,
    "postalCode": postalCode,
    "addressCountry": addressCountry
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "48.5603713",
    "longitude": "18.1657966"
  },
  "sameAs": [
    facebookUrl,
    instagramUrl
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "opens": openFrom,   // "08:00"
      "closes": openUntil  // "20:00"
    },
  ],
};
---

<section id="contact-section" class="pb-16 md:pt-16 bg-[var(--color-light)]">
  <div class="container mx-auto px-6 lg:px-12 max-w-screen-xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <!-- Contact Info -->
      <address class="p-8 rounded-xl bg-white shadow-lg text-[var(--color-dark)] not-italic">
        <div class="space-y-6">
          <div>
            <h3 class="text-xl font-semibold mb-3 flex items-center">Objednávky</h3>
            <p class="flex items-center space-x-2">
              <span>Telefón:</span>
              <a
                href=`tel:${phone}`
                class="text-blue-600 hover:underline focus:underline focus:outline-none cursor-pointer"
                data-copy
                data-value={phone}
              >
                +421 919 236 109
              </a>
            </p>
            <p class="flex items-center space-x-2 mt-2">
              <span>Email:</span>
              <a
                href=`mailto:${email}`
                class="text-blue-600 hover:underline focus:underline focus:outline-none cursor-pointer"
                data-copy
                data-value={email}
              >
                masaze.carbon@gmail.com
              </a>
            </p>
            <p class="flex items-center space-x-2 mt-2">
              <span>Otváracie hodiny:</span>
              <span>Od {openFrom}</span>
              <span>Do {openUntil}</span>
            </p>
          </div>

          <div>
            <h3 class="text-xl font-semibold mb-3 flex items-center">Kde nás nájdete</h3>
            <p
              class="cursor-pointer hover:underline focus:underline focus:outline-none"
              data-copy
              data-value={address}
              tabindex="0"
            >
              {address}
            </p>
            <p class="text-sm mt-1">{directions}</p>
          </div>

          <div>
            <h3 class="text-xl font-semibold mb-3 flex items-center">Sledujte ma:</h3>
            <nav aria-label="Sociálne siete" class="flex space-x-4 ml-2">
              <a
                href={facebookUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 rounded"
              >
                <Image
                  src={facebookIcon}
                  alt="Facebook"
                  width={40}
                  height={40}
                  class="transition-transform hover:scale-110"
                  loading="lazy"
                />
              </a>
              <a
                href={instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 rounded"
              >
                <Image
                  src={instagramIcon}
                  alt="Instagram"
                  width={40}
                  height={40}
                  class="transition-transform hover:scale-110"
                  loading="lazy"
                />
              </a>
            </nav>
          </div>

          <!-- Popup for copy feedback -->
          <div
            id="copy-popup"
            class="fixed left-1/2 bottom-10 z-50 px-4 py-2 rounded bg-[var(--color-dark)] text-[var(--color-light)] text-sm shadow-lg opacity-0 pointer-events-none transition-opacity duration-300"
            style="transform: translateX(-50%);"
          >
            Skopírované!
          </div>
        </div>
      </address>

      <!-- Map -->
      <div class="rounded-xl overflow-hidden shadow-md h-full min-h-[450px]">
        <iframe
          src={mapIframeSrc}
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa Masáže Carbon Topoľčany"
          class="w-full h-full"
        ></iframe>
      </div>
    </div>
  </div>

  <!-- Schema markup -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}/>

  <script>
    // Utility: Detect if device is mobile
    function isMobile() {
      return /Mobi|Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
    }

    document.addEventListener("DOMContentLoaded", () => {
      const popup = document.getElementById("copy-popup");
      const copyables = document.querySelectorAll("[data-copy]");

      copyables.forEach(el => {
        el.addEventListener("click", (e) => {
          // Only copy on desktop
          if (!isMobile()) {
            e.preventDefault();
            const value = el.getAttribute("data-value");
            if (!value) return;
            navigator.clipboard.writeText(value).then(() => {
              popup.style.opacity = "1";
              setTimeout(() => {
                popup.style.opacity = "0";
              }, 1200);
            });
          }
          // On mobile: do nothing, let default behavior happen (call/email)
        });

        // Optional: keyboard accessibility for desktop
        el.addEventListener("keydown", (e) => {
          if (!isMobile() && (e.key === "Enter" || e.key === " ")) {
            e.preventDefault();
            el.click();
          }
        });
      });
    });
  </script>
</section>

<style>
    #contact-section a {
        text-decoration: none;
    }

    #contact-section a:hover,
    #contact-section a:focus {
        text-decoration: underline;
    }

    #contact-section a img:hover {
        filter: brightness(1.2);
    }
</style>
