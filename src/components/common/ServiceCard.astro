---
import ServiceImage from './ServiceImage.astro';

const {image, alt, name, price, description} = Astro.props;
---

<div class="relative shadow-lg overflow-hidden aspect-square w-full">
  <ServiceImage
    src={image}
    alt={alt}
    class="w-full h-full object-cover"
  />
  <div
    class="absolute bottom-0 left-0 right-0 text-[var(--color-light)] py-4 px-6 h-1/3"
    style="background-color: var(--color-dark-85);">
    <div class="flex justify-between items-center mb-1">
      <h3 class="text-lg font-bold">{name}</h3>
      <p class="text-xl font-bold">{price}</p>
    </div>
    <p class="text-sm leading-relaxed">{description}</p>
  </div>
</div>
