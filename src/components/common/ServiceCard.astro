---
import {Image} from "astro:assets";

interface Props {
  image: ImageMetadata;
  alt: string;
  name: string;
  price: string;
  description: string;
  className?: string;
}

const {image, alt, name, price, description, className = ""} = Astro.props as Props;
---

<article
  class={`relative shadow-lg overflow-hidden aspect-square w-full group ${className}`}
  aria-labelledby={`service-${name.replace(/\s+/g, '-').toLowerCase()}-title`}
>
  <!-- Image -->
  <Image
    src={image}
    alt={alt}
    width={400}
    height={400}
    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
    loading="lazy"
    decoding="async"
    fetchpriority="low"
    format="webp"
    quality={80}
  />

  <!-- Gradient Overlay (Background) -->
  <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-dark)] via-transparent/20 to-transparent"/>

  <!-- Semi-Transparent Box (Foreground) -->
  <div
    class="absolute bottom-0 left-0 right-0 h-1/3 bg-[var(--color-dark-85)] text-[var(--color-light)] p-6"
    style="backdrop-filter: blur(2px);"
  >
    <div class="flex justify-between items-center mb-2">
      <h3
        id={`service-${name.replace(/\s+/g, '-').toLowerCase()}-title`}
        class="text-xl font-bold"
      >
        {name}
      </h3>
      <p class="text-xl font-bold">{price}</p>
    </div>
    <p class="text-sm leading-relaxed">{description}</p>
  </div>
</article>
