---
import ServiceCard from "./ServiceCard.astro";
import type {ServiceGridSectionProps} from '../../const/types/serviceTypes';

interface Props extends ServiceGridSectionProps {
}

const {services} = Astro.props;
---

<section class="space-y-8">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[50px]">
      {services.map((service) => (
        <ServiceCard
          image={service.image}
          alt={service.alt}
          name={service.name}
          price={service.price}
          description={service.description}
        />
      ))}
    </div>
  </div>
</section>
