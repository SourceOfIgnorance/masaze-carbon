---
import {Image} from "astro:assets";
import ClockIcon from "../icons/Clock.astro";

const {image, name, description, duration, price} = Astro.props;
---

<tr class="hover:bg-gray-50 transition-colors">
  <td class="py-4 px-4 w-16">
    <Image
      src={image}
      alt={name}
      width={48}
      height={48}
      class="rounded-full object-cover"
    />
  </td>
  <td class="py-4 px-4 w-full">
    <div class="flex flex-col">
      <span class="font-medium text-[var(--color-dark)]">{name}</span>
      {description && (
        <span class="text-sm text-gray-500 mt-1">{description}</span>
      )}
      {duration && (
        <span class="flex items-center text-sm text-gray-500 mt-1">
          <ClockIcon class="w-4 h-4 mr-1"/>
          {duration} min
        </span>
      )}
    </div>
  </td>
  <td class="py-4 px-6 text-right align-middle w-32">
    <div class="relative flex items-center justify-end">
      <div
        class="absolute left-0 right-0 top-1/2 -translate-y-1/2 border-t border-dashed border-gray-300 z-0"
      ></div>
      <span class="relative z-10 bg-white px-2 font-bold text-[var(--color-dark)]">{price}</span>
    </div>
  </td>
</tr>
