---
import MainLayout from "../layouts/MainLayout.astro";
import {pageMetadata} from "../const/pageMetadata";
import Gallery from "../components/gallery/Gallery.astro";
import {galleryImages} from "../const/galleryData";

const imagesForReact = galleryImages.map(img => ({
  src: img.src,
  alt: img.alt,
}));
---

<MainLayout
  title={pageMetadata.galeria.title}
  description={pageMetadata.galeria.description}
>
  <div class="pt-32 pb-16">
    <div class="container mx-auto px-4 max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-[var(--color-dark)]">
        Galéria
      </h1>
      <p class="text-lg text-gray-700 text-center mb-8">
        Pozrite si naše priestory a vybavenie.
      </p>
      <Gallery images={imagesForReact}/>
    </div>
  </div>
</MainLayout>