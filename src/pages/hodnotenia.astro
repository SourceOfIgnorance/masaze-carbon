---
import MainLayout from "../layouts/MainLayout.astro";
import {pageMetadata} from "../const/pageMetadata";
import {getReviewsJsonLd} from "../utils/reviewsJsonLd";
import {userFormReviews} from "../const/userFormReviews";
let reviewsJsonLd = null;

const mockReviews = userFormReviews

let reviews = [];
const baseUrl = import.meta.env.SITE_URL || "http://localhost:8888";

try {
  const response = await fetch(`${baseUrl}/.netlify/functions/get-approved-reviews`);
  if (response.ok) {
    const data = await response.json();
    reviews = data.reviews.map((r) => ({
      id: r.id,
      author: r.name,
      rating: r.rating,
      comment: r.comment,
      datePublished: r.dateSubmitted,
    }));
    reviewsJsonLd = getReviewsJsonLd(reviews);
  } else {
    console.warn("Failed to fetch real reviews, using mock data.");
    reviews = mockReviews;
    reviewsJsonLd = getReviewsJsonLd(reviews)
  }
} catch (error) {
  console.warn("Error fetching reviews, using mock data.", error);
  reviews = mockReviews;
  reviewsJsonLd = getReviewsJsonLd(reviews)
}
---

<style>
    #review-form-section {
        scroll-margin-top: 80px;
    }
</style>

<MainLayout title={pageMetadata.hodnotenia.title}
            description={pageMetadata.hodnotenia.description}
            jsonLd={reviewsJsonLd ? [reviewsJsonLd] : []}>
  <section class="pt-32 pb-16 container mx-auto max-w-4xl px-4">
    <h1 class="text-4xl font-bold text-center mb-6 text-[var(--color-dark)]">
      Hodnotenia našich zákazníkov
    </h1>
    <p class="text-center text-lg mb-12 text-[var(--color-dark-70)]">
      Prečítajte si, čo o nás hovoria naši zákazníci,
      <a href="#review-form-section" id="scroll-to-form"
         class="underline cursor-pointer hover:text-[var(--color-dark)]">
        alebo zanechajte svoje vlastné hodnotenie
      </a>.
    </p>
    <ul
      class="space-y-8"
      aria-label="Zoznam zákazníckych hodnotení"
      role="list"
      id="reviews-list"
    >
      {userFormReviews.length === 0 ? (
        <li class="text-center text-gray-600 italic">
          Zatiaľ tu nie sú žiadne hodnotenia.
        </li>
      ) : (
        userFormReviews.map((review, i) => (
          <li
            key={review.id}
            data-index={i}
            class="review-item p-6 border border-gray-200 rounded-lg shadow-sm bg-white"
            role="article"
            aria-label={`Hodnotenie od ${review.author}`}
          >
            <header class="flex items-center justify-between mb-3">
              <p class="font-semibold text-lg text-[var(--color-dark)]">
                {review.author}
              </p>
              <p
                class="text-yellow-500 font-bold"
                aria-label={`Hodnotenie ${review.rating} z 5 hviezdičiek`}
              >
                {"⭐".repeat(review.rating)}
              </p>
            </header>
            <p class="text-gray-700 whitespace-pre-line">{review.comment}</p>
            <time
              class="block mt-3 text-sm text-gray-500"
              dateTime={review.datePublished}
            >
              {new Date(review.datePublished).toLocaleDateString("sk-SK", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </li>
        ))
      )}
    </ul>
    <div class="flex justify-center items-center space-x-4 mt-8" id="pagination-controls">
      <button id="prev-page" class="px-4 py-2 bg-gray-200 rounded disabled:opacity-50" disabled>
        Predošlá
      </button>
      <span id="page-info" class="text-gray-700"></span>
      <button id="next-page" class="px-4 py-2 bg-gray-200 rounded disabled:opacity-50">
        Ďalšia
      </button>
    </div>

    <!-- Review Submission Form -->
    <section
      id="review-form-section"
      class="mt-16 bg-[var(--color-light)] p-8 rounded-lg bg-white shadow-md max-w-xl mx-auto"
      aria-labelledby="form-title"
    >
      <h2
        id="form-title"
        class="text-2xl font-semibold mb-6 text-[var(--color-dark)] text-center"
      >
        Zanechajte svoje hodnotenie
      </h2>

      <form
        name="user-review"
        method="POST"
        netlify-honeypot="bot-field"
        class="space-y-6"
        aria-describedby="form-instructions"
        netlify
      >
        <input type="hidden" name="form-name" value="user-review"/>
        <div class="hidden" aria-hidden="true">
          <label>
            Don’t fill this out if you’re human:
            <input name="bot-field"/>
          </label>
        </div>

        <p id="form-instructions" class="sr-only">
          Vyplňte meno, hodnotenie hviezdičkami, komentár a voliteľne email.
          Súhlasíte so spracovaním osobných údajov.
        </p>

        <!-- Name -->
        <div>
          <label
            for="name"
            class="block mb-1 font-medium text-[var(--color-dark)]"
          >Meno <sup class="text-red-600">*</sup></label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            minlength="2"
            maxlength="50"
            class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-[var(--color-dark)]"
            placeholder="Vaše meno"
            autocomplete="name"
          />
        </div>

        <!-- Rating -->
        <div>
          <label
            for="rating"
            class="block mb-1 font-medium text-[var(--color-dark)]"
          >Hodnotenie <sup class="text-red-600">*</sup></label
          >
          <p id="rating-help" class="text-sm text-gray-500 mt-1">
            Vyberte hodnotenie od 1 do 5 hviezdičiek.
          </p>
          <fieldset class="rating flex flex-row-reverse justify-center gap-1 py-2" aria-label="Hodnotenie">
            <input type="radio" id="star5" name="rating" value="5" class="hidden peer" required/>
            <label for="star5" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400"
                   title="5 hviezdičiek">
              <!-- Star SVG filled -->
              <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.97a1 1 0 00.95.69h4.178c.969 0 1.371 1.24.588 1.81l-3.39 2.462a1 1 0 00-.364 1.118l1.287 3.97c.3.921-.755 1.688-1.54 1.118l-3.39-2.462a1 1 0 00-1.175 0l-3.39 2.462c-.784.57-1.838-.197-1.539-1.118l1.287-3.97a1 1 0 00-.364-1.118L2.047 9.397c-.783-.57-.38-1.81.588-1.81h4.178a1 1 0 00.95-.69l1.286-3.97z"/>
              </svg>
            </label>

            <input type="radio" id="star4" name="rating" value="4" class="hidden peer"/>
            <label for="star4" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400"
                   title="4 hviezdičky">
              <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.97a1 1 0 00.95.69h4.178c.969 0 1.371 1.24.588 1.81l-3.39 2.462a1 1 0 00-.364 1.118l1.287 3.97c.3.921-.755 1.688-1.54 1.118l-3.39-2.462a1 1 0 00-1.175 0l-3.39 2.462c-.784.57-1.838-.197-1.539-1.118l1.287-3.97a1 1 0 00-.364-1.118L2.047 9.397c-.783-.57-.38-1.81.588-1.81h4.178a1 1 0 00.95-.69l1.286-3.97z"/>
              </svg>
            </label>

            <input type="radio" id="star3" name="rating" value="3" class="hidden peer"/>
            <label for="star3" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400"
                   title="3 hviezdičky">
              <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.97a1 1 0 00.95.69h4.178c.969 0 1.371 1.24.588 1.81l-3.39 2.462a1 1 0 00-.364 1.118l1.287 3.97c.3.921-.755 1.688-1.54 1.118l-3.39-2.462a1 1 0 00-1.175 0l-3.39 2.462c-.784.57-1.838-.197-1.539-1.118l1.287-3.97a1 1 0 00-.364-1.118L2.047 9.397c-.783-.57-.38-1.81.588-1.81h4.178a1 1 0 00.95-.69l1.286-3.97z"/>
              </svg>
            </label>

            <input type="radio" id="star2" name="rating" value="2" class="hidden peer"/>
            <label for="star2" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400"
                   title="2 hviezdičky">
              <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.97a1 1 0 00.95.69h4.178c.969 0 1.371 1.24.588 1.81l-3.39 2.462a1 1 0 00-.364 1.118l1.287 3.97c.3.921-.755 1.688-1.54 1.118l-3.39-2.462a1 1 0 00-1.175 0l-3.39 2.462c-.784.57-1.838-.197-1.539-1.118l1.287-3.97a1 1 0 00-.364-1.118L2.047 9.397c-.783-.57-.38-1.81.588-1.81h4.178a1 1 0 00.95-.69l1.286-3.97z"/>
              </svg>
            </label>

            <input type="radio" id="star1" name="rating" value="1" class="hidden peer"/>
            <label for="star1" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400"
                   title="1 hviezdička">
              <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.97a1 1 0 00.95.69h4.178c.969 0 1.371 1.24.588 1.81l-3.39 2.462a1 1 0 00-.364 1.118l1.287 3.97c.3.921-.755 1.688-1.54 1.118l-3.39-2.462a1 1 0 00-1.175 0l-3.39 2.462c-.784.57-1.838-.197-1.539-1.118l1.287-3.97a1 1 0 00-.364-1.118L2.047 9.397c-.783-.57-.38-1.81.588-1.81h4.178a1 1 0 00.95-.69l1.286-3.97z"/>
              </svg>
            </label>
          </fieldset>
        </div>

        <!-- Comment -->
        <div>
          <label
            for="comment"
            class="block mb-1 font-medium text-[var(--color-dark)]"
          >Komentár <sup class="text-red-600">*</sup></label
          >
          <textarea
            id="comment"
            name="comment"
            required
            rows="4"
            minlength="20"
            maxlength="1000"
            class="w-full rounded border border-gray-300 px-3 py-2 resize-y focus:outline-none focus:ring-2 focus:ring-[var(--color-dark)]"
            placeholder="Napíšte svoj názor alebo skúsenosť"
          ></textarea>
        </div>

        <!-- Email (optional) -->
        <div>
          <label
            for="email"
            class="block mb-1 font-medium text-[var(--color-dark)]"
          >Email (nepovinné)</label
          >
          <input
            type="email"
            id="email"
            name="email"
            autocomplete="email"
            placeholder="Váš email"
            class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-[var(--color-dark)]"
          />
          <p class="text-sm text-gray-500 mt-1">
            Email použijeme len na prípadný kontakt, nebude zverejnený.
          </p>
        </div>

        <!-- Consent Checkbox -->
        <div class="flex items-center">
          <input
            type="checkbox"
            id="consent"
            name="consent"
            required
            class="mr-2 focus:ring-[var(--color-dark)]"
          />
          <label for="consent" class="text-[var(--color-dark)] text-sm">
            Súhlasím so spracovaním osobných údajov podľa
            <a
              href="/privacy-policy"
              target="_blank"
              rel="noopener noreferrer"
              class="underline hover:text-[var(--color-dark-70)]"
            >zásad ochrany osobných údajov</a
            >.
          </label>
        </div>

        <div id="form-message" role="alert" aria-live="polite" class="mb-4 text-center text-sm font-semibold"></div>
        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-[var(--color-dark)] text-[var(--color-light)] py-3 rounded font-semibold hover:bg-[var(--color-dark-85)] transition-colors duration-300"
        >
          Odoslať hodnotenie
        </button>
      </form>
    </section>
  </section>

  <!-- Optional: Client-side form enhancements (validation, submission feedback) -->
  <script is:inline>
    (() => {
      const form = document.querySelector('form[name="user-review"]');
      if (!form) return;

      form.addEventListener("submit", (e) => {
        // Basic client-side validation example (optional)
        const consent = form.querySelector("#consent");
        if (!consent.checked) {
          e.preventDefault();
          alert("Musíte súhlasiť so spracovaním osobných údajov.");
          consent.focus();
          return;
        }
        // Could add more validation or async submission here
      });
    })();
  </script>
  <script is:inline>
    (() => {
      const reviewsPerPage = 5;
      const reviews = document.querySelectorAll(".review-item");
      const totalReviews = reviews.length;
      const totalPages = Math.ceil(totalReviews / reviewsPerPage);

      const prevBtn = document.getElementById("prev-page");
      const nextBtn = document.getElementById("next-page");
      const pageInfo = document.getElementById("page-info");

      let currentPage = 1;

      function showPage(page) {
        currentPage = page;
        const start = (page - 1) * reviewsPerPage;
        const end = start + reviewsPerPage;

        reviews.forEach((review, index) => {
          review.style.display = index >= start && index < end ? "block" : "none";
        });

        pageInfo.textContent = `Strana ${currentPage} z ${totalPages}`;

        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage === totalPages;

        const reviewsList = document.getElementById("reviews-list");
        if (reviewsList) {
          window.scrollTo({top: 0, behavior: "smooth"});
        }
      }

      prevBtn.addEventListener("click", () => {
        if (currentPage > 1) showPage(currentPage - 1);
      });

      nextBtn.addEventListener("click", () => {
        if (currentPage < totalPages) showPage(currentPage + 1);
      });

      if (totalPages > 0) {
        showPage(1);
      } else {
        pageInfo.textContent = "Žiadne hodnotenia na zobrazenie.";
        prevBtn.disabled = true;
        nextBtn.disabled = true;
      }
    })();
  </script>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.querySelector("form[name='user-review']");
      const messageEl = document.getElementById("form-message");

      if (!form || !messageEl) return;

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        messageEl.textContent = "";
        messageEl.className = "mb-4 text-center text-sm font-semibold";

        const formData = new FormData(form);

        try {
          const response = await fetch(form.action || "/", {
            method: form.method || "POST",
            body: formData,
            headers: {
              "Accept": "application/json",
            },
          });

          if (response.ok) {
            messageEl.textContent = "Hodnotenie uložené. Na stránke sa zobrazí onedlho. Ďakujeme!";
            messageEl.classList.add("text-green-600");
            form.reset();
          } else {
            throw new Error("Nastala chyba. Skúste to, prosím, znova..");
          }
        } catch (error) {
          messageEl.textContent = error.message;
          messageEl.classList.add("text-red-600");
        }
      });
    });
  </script>
</MainLayout>
