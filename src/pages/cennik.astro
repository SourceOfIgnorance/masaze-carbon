---
import MainLayout from "../layouts/MainLayout.astro";
import PricingTable from "../components/common/PricingTable.astro";
import {classicMassages, specialOffers, giftCards} from "../const/serviceData";

const categories = [
  {
    id: "massage",
    title: "Masážne služby",
    services: classicMassages
  },
  {
    id: "special",
    title: "Špeciálne ponuky",
    services: specialOffers
  },
  {
    id: "gift",
    title: "Darčekové poukazy",
    services: giftCards
  }
];
---

<MainLayout title="Cenník | Masáže Carbon" description="Kompletný cenník masážnych služieb">
  <div class="pt-32 pb-16">
    <div class="container mx-auto px-4 max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-[var(--color-dark)]">Cenník</h1>
      {categories.map((category) => (
        <PricingTable
          key={category.id}
          categoryTitle={category.title}
          services={category.services}
        />
      ))}
    </div>
  </div>
</MainLayout>
