---
import MainLayout from "../layouts/MainLayout.astro";
import {pageMetadata} from "../const/pageMetadata";

import PricingCategory from "../components/services/PricingCategory.astro";
import {classicMassages, specialOffers, giftCards} from "../const/serviceData";
const allServices = [...classicMassages, ...specialOffers, ...giftCards];

import {getServiceJsonLd} from "../utils/serviceJsonLd";
const serviceJsonLd = getServiceJsonLd(allServices)
import {richServiceJsonLd} from "../utils/richServiceJsonLd";

const categories = [
  {
    id: "massage",
    title: "Masážne služby",
    services: classicMassages,
    description: "Vy rozhodujete, my sa prispôsobíme. Sami si určíte, čo vaše telo potrebuje. \n" +
      "Zameriame sa na konkrétnu oblasť, spojíme viacero techník alebo vytvoríme relaxačný celok."
  },
  {
    id: "special",
    title: "Špeciálne ponuky",
    services: specialOffers,
    description: null
  },
  {
    id: "gift",
    title: "Akcie a Darčekové poukazy",
    services: giftCards,
    description: "Využite výhodné akcie na masáže, ktoré práve ponúkame!\n" +
      "Stačí ma kontaktovať telefonicky – dohodneme si termín aj všetky detaily zliav."
  }
];
---

<MainLayout
  title={pageMetadata.cennik.title}
  description={pageMetadata.cennik.description}
  jsonLd={[serviceJsonLd, richServiceJsonLd]}
>
  <div class="pt-32 pb-8">
    <div class="container mx-auto px-4 max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-[var(--color-dark)]">
        Cenník masážnych služieb
      </h1>
      <p class="text-lg text-center mb-8">
        Pozrite si náš kompletný cenník a vyberte si masáž, ktorá vám najviac vyhovuje.
      </p>
      <ul>
        {categories.map((category) => (
          <PricingCategory key={category.id} {...category}/>
        ))}
      </ul>
    </div>
  </div>
  <button
    id="floating-order-button"
    type="button"
    aria-label="Prejsť na sekciu objednať"
    class="fixed bottom-6 right-6 z-50 bg-[var(--color-dark)] text-[var(--color-light)] px-6 py-3 rounded-full font-semibold shadow-lg hover:bg-[var(--color-dark-85)] transition-colors duration-300 md:hidden"
  >
    Objednať
  </button>

</MainLayout>

<script is:inline>
  const floatingOrderBtn = document.getElementById("floating-order-button");

[floatingOrderBtn, document.getElementById("order-button"), document.getElementById("mobile-order-button")]
  .filter(Boolean)
  .forEach(btn => {
    btn.addEventListener("click", () => {
      const contactSection = document.getElementById("contact-section");
      if (contactSection) {
        contactSection.scrollIntoView({ behavior: "smooth" });
      }
    });
  });
</script>